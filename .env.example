# AI provider for the per-card news analysis:
#   ollama     - free local model, runs on your Mac (default)
#   anthropic  - Claude API (paid, needs ANTHROPIC_API_KEY)
#   none       - skip the per-card AI, technicals only (fastest)
AI_PROVIDER=ollama

# --- Local model (Ollama), used when AI_PROVIDER=ollama ---
# Which local model Ollama uses. llama3.2:3b is light enough for 8 GB Macs.
# If you have 16+ GB RAM, llama3.1:8b gives better analysis.
OLLAMA_MODEL=llama3.2:3b

# How many stocks to analyze in parallel locally. 2 is safe on an 8 GB M1;
# bump to 3-4 if you have 16+ GB RAM. Needs Ollama started with a matching
# OLLAMA_NUM_PARALLEL (start.sh sets it to 2 automatically).
OLLAMA_CONCURRENCY=2

# Point at a remote Ollama instead of localhost (e.g. a GPU box on your network).
# OLLAMA_URL=http://192.168.1.50:11434

# --- Hosted analysis (Anthropic / Claude) ---
# Required for the deep analysis, the pick triage, the morning re-check, and the daily notes.
# The per-card analysis above can stay on the free local model; these features cannot.
# ANTHROPIC_API_KEY=

# Optional model overrides (sensible defaults are built in). Opus is used for the
# deeper trade case; Sonnet for the lighter triage and notes.
# TRADE_CASE_MODEL=claude-opus-4-8
# RECOMMEND_MODEL=claude-sonnet-4-6
# DAILY_NOTES_MODEL=claude-sonnet-4-6

# --- Push notifications (optional, used by the nightly advisor) ---
# Free ntfy.sh topic to receive phone pushes when setups are proposed or trades fire.
# Pick a long, unguessable topic name and subscribe to it in the ntfy app.
# NTFY_TOPIC=
# NTFY_SERVER=https://ntfy.sh
